      </tr>
      <tr
        class="border-b transition-colors border-border hover:bg-neutral-50 data-[state=selected]:bg-neutral-100"
      >
        <td
          class="p-2 align-middle [&:has([role=checkbox])]:pr-0 [&>[role=checkbox]]:translate-y-[2px] px-3 py-2 text-foreground"
        >
