exports[`shared component set — Amazon-official snapshots > MetricCard with label/value/hint/trend/icon renders its official markup 1`] = `
<div
  class="rounded-md border border-border bg-card text-card-foreground shadow-sm p-4"
>
  <div
    class="flex items-start justify-between gap-2"
  >
    <p
      class="text-xs font-medium uppercase tracking-wide text-muted-foreground"
    >
      Items resold
    </p>
    <svg
      aria-hidden="true"
      class="lucide lucide-recycle size-4 shrink-0 text-muted-foreground"
      fill="none"
      height="24"
      stroke="currentColor"
      stroke-linecap="round"
      stroke-linejoin="round"
      stroke-width="2"
      viewBox="0 0 24 24"
      width="24"
      xmlns="http://www.w3.org/2000/svg"
    >
      <path
        d="M7 19H4.815a1.83 1.83 0 0 1-1.57-.881 1.785 1.785 0 0 1-.004-1.784L7.196 9.5"
      />
      <path
        d="M11 19h8.203a1.83 1.83 0 0 0 1.556-.89 1.784 1.784 0 0 0 0-1.775l-1.226-2.12"
      />
      <path
        d="m14 16-3 3 3 3"
      />
      <path
        d="M8.293 13.596 7.196 9.5 3.1 10.598"
      />
      <path
        d="m9.344 5.811 1.093-1.892A1.83 1.83 0 0 1 11.985 3a1.784 1.784 0 0 1 1.546.888l3.943 6.843"
      />
      <path
        d="m13.378 9.633 4.096 1.098 1.097-4.096"
      />
    </svg>
  </div>
  <p
    class="mt-2 font-heading text-2xl font-semibold leading-none text-foreground"
  >
    1450
  </p>
  <p
    class="mt-1.5 text-xs text-muted-foreground"
  >
    vs. 1,200 last quarter
  </p>
  <p
    class="mt-2 flex items-center gap-1 text-xs font-medium text-success"
  >
    <svg
      aria-hidden="true"
      class="lucide lucide-arrow-up size-3.5"
      fill="none"
      height="24"
      stroke="currentColor"
      stroke-linecap="round"
      stroke-linejoin="round"
      stroke-width="2"
      viewBox="0 0 24 24"
      width="24"
      xmlns="http://www.w3.org/2000/svg"
    >
      <path
        d="m5 12 7-7 7 7"
      />
      <path
        d="M12 19V5"
      />
    </svg>
    <span
      class="sr-only"
    >
      Trending up
      : 
    </span>
    +12% vs last week
  </p>
</div>
`;

exports[`shared component set — Amazon-official snapshots > Table with header + rows renders its official markup 1`] = `
<div
  class="relative w-full overflow-auto"
>
  <table
    class="w-full caption-bottom text-foreground text-sm"
  >
    <thead
      class="[&_tr]:border-b bg-neutral-50 [&_tr]:border-border"
    >
      <tr
        class="border-b transition-colors border-border hover:bg-neutral-50 data-[state=selected]:bg-neutral-100"
      >
        <th
          class="text-left align-middle [&:has([role=checkbox])]:pr-0 [&>[role=checkbox]]:translate-y-[2px] h-9 px-3 font-medium text-foreground"
        >
          Item
        </th>
        <th
          class="text-left align-middle [&:has([role=checkbox])]:pr-0 [&>[role=checkbox]]:translate-y-[2px] h-9 px-3 font-medium text-foreground"
        >
          Condition
        </th>
      </tr>
    </thead>
    <tbody
      class="[&_tr:last-child]:border-0"
    >
      <tr
        class="border-b transition-colors border-border hover:bg-neutral-50 data-[state=selected]:bg-neutral-100"
      >
        <td
          class="p-2 align-middle [&:has([role=checkbox])]:pr-0 [&>[role=checkbox]]:translate-y-[2px] px-3 py-2 text-foreground"
        >
          Echo Dot
        </td>
        <td
          class="p-2 align-middle [&:has([role=checkbox])]:pr-0 [&>[role=checkbox]]:translate-y-[2px] px-3 py-2 text-foreground"
        >
          Like new
